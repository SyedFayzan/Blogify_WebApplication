<!DOCTYPE html>
<html lang="en">
<head>
    <title>All Articles | Blogify</title>
    <%- include("partials/head") %>
</head>

<body class="bg-light">

<%- include("partials/navbar") %>


<div class="container py-5">


    <div class="text-center mb-5">

        <h1 class="fw-bold">
            Explore Developer Articles
        </h1>

        <p class="text-muted">
            Discover tutorials, tips, and programming guides shared by developers.
        </p>

    </div>



    <% if(blogs.length === 0){ %>

        <div class="alert alert-info text-center">
            No articles have been published yet.
        </div>

    <% } %>




    <div class="row">


        <% blogs.forEach(blog=>{ %>


        <div class="col-lg-4 col-md-6 mb-4">


            <div class="card h-100 shadow border-0 rounded-4">


                <img
                    src="<%= blog.coverImageURL %>"
                    class="card-img-top"
                    style="height:220px;object-fit:cover;"
                    alt="<%= blog.title %>"
                >



                <div class="card-body d-flex flex-column">



                    <span class="badge bg-warning text-dark mb-3 align-self-start">
                        <%= blog.category %>
                    </span>



                    <h4 class="fw-bold">

                        <%= blog.title %>

                    </h4>




                    <small class="text-muted">

                        By <%= blog.createdBy.name %>

                    </small>




                    <p class="mt-3 flex-grow-1">

                        <%= blog.body.substring(0,120) %>...

                    </p>




                    <a
                        href="/blog/<%= blog._id %>"
                        class="btn btn-dark mt-auto"
                    >
                        Read Article
                    </a>



                </div>


            </div>


        </div>


        <% }) %>


    </div>


</div>


<%- include("partials/footer") %>


</body>
</html>