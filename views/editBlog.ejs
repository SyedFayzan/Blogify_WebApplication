<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Blogify | Add Blog</title>
    <%- include("partials/head") %>
  </head>

  <body class="bg-light">
    <%- include("partials/navbar") %>

    <div class="container py-5">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="card shadow border-0 rounded-4">
            <div class="card-body p-5">
              <h2 class="fw-bold mb-1">
                <i class="bi bi-pencil-square text-warning"></i>
                Write a New Blog
              </h2>

              <p class="text-muted mb-4">
                Share your knowledge with developers around the world.
              </p>

              <form
                action="/blog/edit/<%= blog._id %>"
                method="POST"
                enctype="multipart/form-data"
              >
                <!-- Blog Title -->
                <div class="mb-4">
                  <label class="form-label fw-semibold"> Blog Title </label>

                  <input
                    type="text"
                    name="title"
                    class="form-control form-control-lg"
                    value="<%= blog.title %>"
                    required
                  />
                </div>
                <div class="mb-4">

<label class="form-label fw-semibold">
    Article Category
</label>


<select
name="category"
class="form-select form-select-lg"
required
>


<option value="JavaScript"
<%= blog.category === "JavaScript" ? "selected" : "" %>>
JavaScript
</option>



<option value="Node.js"
<%= blog.category === "Node.js" ? "selected" : "" %>>
Node.js
</option>



<option value="React"
<%= blog.category === "React" ? "selected" : "" %>>
React
</option>



<option value="MongoDB"
<%= blog.category === "MongoDB" ? "selected" : "" %>>
MongoDB
</option>



<option value="AI"
<%= blog.category === "AI" ? "selected" : "" %>>
Artificial Intelligence
</option>



<option value="DSA"
<%= blog.category === "DSA" ? "selected" : "" %>>
DSA
</option>



<option value="Web Development"
<%= blog.category === "Web Development" ? "selected" : "" %>>
Web Development
</option>


</select>


</div>

                <!-- Cover Image -->
                <div class="mb-4">
                  <label class="form-label fw-semibold"> Cover Image </label>
                  <img
                    src="<%= blog.coverImageURL %>"
                    class="img-fluid rounded mb-3"
                    style="max-height: 250px"
                  />
                  <input
                    type="file"
                    name="coverImage"
                    class="form-control"
                    accept="image/*"
                  />
                </div>

                <!-- Blog Content -->
                <div class="mb-4">
                  <label class="form-label fw-semibold"> Content </label>

                  <textarea name="body" rows="12" class="form-control" required>
<%= blog.body %></textarea
                  >
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-between">
                  <a href="/" class="btn btn-outline-secondary px-4">
                    Cancel
                  </a>

                  <button
                    type="submit"
                    class="btn btn-warning px-5 fw-semibold"
                  >
                    <i class="bi bi-send-fill me-2"></i>
                    Update Blog
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
